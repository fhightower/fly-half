{
  "name": "playbook-gui",
  "version": "0.1.0",
  "description": "Visual editor for agent playbooks and scenarios stored as YAML files",
  "license": "MIT",
  "type": "module",
  "bin": {
    "playbook-gui": "bin/cli.js"
  },
  "files": [
    "bin",
    "server",
    "dist"
  ],
  "scripts": {
    "dev": "node bin/cli.js ../ --no-open & vite",
    "build": "vite build",
    "start": "node bin/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.19.0",
    "js-yaml": "^4.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@codemirror/lang-yaml": "^6.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@uiw/react-codemirror": "^4.23.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "supertest": "^7.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
